    "\n",
    "# EXPECTED CALIBRATION ERROR (ECE)\n",
    "def compute_ece(y_true, y_prob, n_bins=10):\n",
    "    bins      = np.linspace(0, 1, n_bins + 1)\n",
    "    ece       = 0.0\n",
    "    n_samples = len(y_true)\n",
    "\n",
    "    for i in range(n_bins):\n",
    "        mask = (y_prob >= bins[i]) & (y_prob < bins[i+1])\n",
    "        if mask.sum() == 0:\n",
    "            continue\n",
    "        bin_acc  = y_true[mask].mean()\n",
    "        bin_conf = y_prob[mask].mean()\n",
    "        bin_size = mask.sum()\n",
    "        ece += (bin_size / n_samples) * abs(bin_acc - bin_conf)\n",
    "\n",
    "    return ece\n",
    "\n",
    "y_true_arr = np.array(y_test)\n",
    "\n",
    "ece_uncal = compute_ece(y_true_arr, y_prob_uncal)\n",
    "ece_platt = compute_ece(y_true_arr, y_prob_platt)\n",
    "ece_iso   = compute_ece(y_true_arr, y_prob_iso)\n",
    "\n",
    "print(\"=\" * 50)\n",
    "print(\"EXPECTED CALIBRATION ERROR (ECE)\")\n",
    "print(\"=\" * 50)\n",
    "print(f\"ECE — Uncalibrated: {ece_uncal:.4f}\")\n",
    "print(f\"ECE — Platt:        {ece_platt:.4f}\")\n",
    "print(f\"ECE — Isotonic:     {ece_iso:.4f}\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "cal_summary = pd.DataFrame({\n",
    "    'Method':      ['Uncalibrated', 'Platt Scaling',\n",
