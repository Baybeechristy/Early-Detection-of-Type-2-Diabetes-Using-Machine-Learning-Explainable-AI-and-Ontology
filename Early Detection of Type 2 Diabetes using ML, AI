    "                    round(b_iso,4)],\n",
    "    'ECE':         [round(ece_uncal,4), round(ece_platt,4),\n",
    "                    round(ece_iso,4)]\n",
    "})\n",
    "print(\"\\nCalibration Summary:\")\n",
    "print(cal_summary.to_string(index=False))"
