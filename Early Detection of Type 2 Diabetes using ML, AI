    "\n",
    "# SECTION 11 — CLINICAL RULE CONTRADICTION LAYER\n",
    "\n",
    "def clinical_rule_check(a1c, glucose, ml_prob,\n",
    "                        threshold=0.15):\n",
    "    \"\"\"\n",
    "    Compares ML predicted probability against ADA\n",
    "    diagnostic criteria. Returns contradiction warning\n",
    "    if conflict detected.\n",
    "\n",
    "    Parameters:\n",
    "        a1c      : float or NaN — HbA1c percentage\n",
    "        glucose  : float or NaN — fasting plasma glucose\n",
    "        ml_prob  : float — model predicted probability\n",
    "        threshold: float — classification threshold\n",
    "\n",
    "    Returns:\n",
    "        ml_decision : str\n",
    "        status      : str\n",
    "        explanation : str\n",
    "    \"\"\"\n",
    "    ml_decision    = (\"High Risk\" if ml_prob >= threshold\n",
    "                      else \"Low Risk\")\n",
    "    clinical_flag  = False\n",
    "    reasons        = []\n",
    "\n",
    "    if pd.notna(a1c) and a1c >= 6.5:\n",
    "        clinical_flag = True\n",
    "        reasons.append(f\"A1C = {a1c}% (≥ 6.5%)\")\n",
    "\n",
    "    if pd.notna(glucose) and glucose >= 126:\n",
    "        clinical_flag = True\n",
    "        reasons.append(\n",
    "            f\"Glucose = {glucose} mg/dL (≥ 126)\"\n",
    "        )\n",
    "\n",
    "    if clinical_flag and ml_decision == \"Low Risk\":\n",
    "        status = \"CONTRADICTION WARNING\"\n",
    "        explanation = (\n",
    "            f\"Model predicts Low Risk \"\n",
    "            f\"(prob={ml_prob:.3f}) but clinical \"\n",
    "            f\"values indicate diabetes: \"\n",
    "            f\"{', '.join(reasons)}\"\n",
    "        )\n",
    "    elif clinical_flag and ml_decision == \"High Risk\":\n",
    "        status = \"AGREEMENT — High Risk Confirmed\"\n",
    "        explanation = (\n",
    "            f\"Model and clinical rules agree: \"\n",
    "            f\"High Risk. Flags: {', '.join(reasons)}\"\n",
    "        )\n",
    "    elif not clinical_flag and ml_decision == \"High Risk\":\n",
    "        status = \"MODEL FLAG — Labs Within Normal Range\"\n",
    "        explanation = (\n",
    "            f\"Model predicts High Risk \"\n",
    "            f\"(prob={ml_prob:.3f}) but A1C and \"\n",
    "            f\"glucose are within normal range. \"\n",
    "            f\"Consider other risk factors.\"\n",
    "        )\n",
    "    else:\n",
    "        status = \"AGREEMENT — Low Risk\"\n",
    "        explanation = (\n",
    "            \"Model and clinical rules agree: Low Risk.\"\n",
    "        )\n",
    "\n",
    "    return ml_decision, status, explanation\n",
    "\n",
    "print(\"Clinical rule function defined\")"
   ]
